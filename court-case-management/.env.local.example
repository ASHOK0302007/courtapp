# Supabase project settings — Project Settings > API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER expose to the client or commit this value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to build absolute links in emails/notifications
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email provider for notification delivery (Resend). Optional for local dev.
RESEND_API_KEY=your-resend-key
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.example

# Shared secret checked on the Supabase Database Webhook that calls
# /api/webhooks/notification-email — prevents unauthenticated calls to that route.
SUPABASE_WEBHOOK_SECRET=a-long-random-string
